# Copy to .env and fill in values
DATABASE_URL=sqlite+aiosqlite:///data/swarmer.db
AUTH_HASH_FILE=auth/password.hash
K8S_IN_CLUSTER=false
HOST=0.0.0.0
PORT=8080

# Images used when launching session pods (one per agent tool)
AGENT_IMAGE=ghcr.io/anomalyco/opencode:latest
AGENT_IMAGE_OPENCODE=ghcr.io/anomalyco/opencode:latest
AGENT_IMAGE_CRUSH=ghcr.io/gurnben/crush-container:latest
CRUSH_VERSION=0.57.0
DEFAULT_AGENT_TOOL=opencode
# Optional: image pull secret name in the workspace namespace
AGENT_IMAGE_PULL_SECRET=
